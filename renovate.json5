{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeDisabled",
    ":dependencyDashboard"
  ],
  "enabledManagers": ["npm"],
  "prConcurrentLimit": 10,
  "schedule": [
    "21-23,0-5 * * 1-5",
    "* * * * 0,6"
  ],
  "packageRules": [
    {
      "description": "Cap nx and vitest majors to weekly so the monorepo doesn't get flooded",
      "matchPackageNames": ["nx", "@nx/**", "vitest", "@vitest/**"],
      "matchUpdateTypes": ["major"],
      "schedule": ["0-5 * * 1"]
    }
  ]
}
