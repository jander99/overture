{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeDisabled",
    ":dependencyDashboard"
  ],
  "enabledManagers": ["npm"],
  "prConcurrentLimit": 10,
  "schedule": [
    "after 9pm on weekdays",
    "before 6am on weekdays",
    "any time on weekends"
  ],
  "packageRules": [
    {
      "description": "Cap nx and vitest majors to weekly so the monorepo doesn't get flooded",
      "matchPackageNames": ["nx", "@nx/**", "vitest", "@vitest/**"],
      "matchUpdateTypes": ["major"],
      "schedule": ["before 6am on monday"]
    }
  ]
}
